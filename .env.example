# ============================================================================
# Keyword Intelligence Pipeline — Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# ============================================================================

# === Application Core ===
APP_ENV=development                    # development | staging | production
APP_TITLE=Keyword Intelligence Pipeline
DEBUG=false                            # Enable debug mode (true/false)

# === Logging ===
LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=console                     # console (human-readable) | json (structured)
LOG_FILE_ENABLED=false                 # Write logs to logs/ directory (true/false)
LOG_ROTATION=10 MB                     # Log file rotation size
LOG_RETENTION=7 days                   # Log file retention period

# === AI Provider Configuration (Phase 2+) ===
# Uncomment and configure when implementing AI features.
#
# AI_PROVIDER=google                   # google | openai | anthropic
# AI_MODEL=gemini-2.5-flash            # Model identifier for the chosen provider
# AI_API_KEY=                           # API key — use a secrets manager in production
# AI_TEMPERATURE=0.3                    # Generation temperature (0.0 - 1.0)
# AI_MAX_TOKENS=4096                    # Maximum output tokens per request
# AI_TIMEOUT=30                         # Request timeout in seconds
# AI_MAX_RETRIES=3                      # Number of retries on transient failures

# === Data Sources (Phase 3+) ===
# Uncomment and configure when implementing data persistence.
#
# DATABASE_URL=                         # Primary database connection string
# REDIS_URL=                            # Cache / message broker connection string

# === Search APIs (Phase 3+) ===
# Uncomment and configure when implementing search data ingestion.
#
# GOOGLE_SEARCH_API_KEY=                # Google Custom Search API key
# GOOGLE_SEARCH_ENGINE_ID=              # Google Programmable Search Engine ID
# SEMRUSH_API_KEY=                      # SEMrush API key
