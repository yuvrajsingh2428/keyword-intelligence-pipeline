# ============================================================================
# Keyword Intelligence Pipeline — Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# ============================================================================

# === Application Core ===
APP_ENV=development                    # development | staging | production
APP_TITLE=Keyword Intelligence Pipeline
DEBUG=false                            # Enable debug mode (true/false)

# === Logging ===
LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=console                     # console (human-readable) | json (structured)
LOG_FILE_ENABLED=false                 # Write logs to logs/ directory (true/false)
LOG_ROTATION=10 MB                     # Log file rotation size
LOG_RETENTION=7 days                   # Log file retention period

# === AI Provider Configuration ===
AI_PROVIDER=mock                       # mock | gemini | openrouter | ollama
AI_MODEL=gemini-3.5-flash              # Model identifier for the chosen provider
AI_BATCH_SIZE=100                      # Number of keywords per AI classification batch
AI_TIMEOUT=60                          # Request timeout in seconds

# --- Google Gemini API Keys (rotation pool) ---
# The pipeline rotates through these keys to handle rate limits.
GOOGLE_GEMINI_API_KEY_1=               # API key 1 for Google Gemini
GOOGLE_GEMINI_API_KEY_2=               # API key 2 for Google Gemini
GOOGLE_GEMINI_API_KEY_3=               # API key 3 for Google Gemini
GOOGLE_GEMINI_API_KEY_4=               # API key 4 for Google Gemini
GOOGLE_GEMINI_API_KEY_5=               # API key 5 for Google Gemini

# --- OpenRouter Fallback ---
OPEN_ROUTER_API_KEY=                   # API key for OpenRouter fallback provider
OPEN_ROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
OPEN_ROUTER_MODEL=google/gemini-2.5-flash

# --- Ollama (Local LLM) ---
OLLAMA_URL=http://localhost:11434      # Ollama REST API base URL

# === Search Volume ===
SEARCH_VOLUME_PROVIDER=mock            # mock | api (provider for fetching search volume)
SEARCH_VOLUME_BATCH_SIZE=500           # Batch size for search volume requests

# === Reporting ===
REPORT_FORMAT=json                     # csv | excel | json
REPORT_OUTPUT_DIR=reports              # Directory for exported report files

# === Data Sources (Future) ===
# Uncomment and configure when implementing data persistence.
#
# DATABASE_URL=                        # Primary database connection string
# REDIS_URL=                           # Cache / message broker connection string

# === Search APIs (Future) ===
# Uncomment and configure when implementing search data ingestion.
#
# GOOGLE_SEARCH_API_KEY=               # Google Custom Search API key
# GOOGLE_SEARCH_ENGINE_ID=             # Google Programmable Search Engine ID
# SEMRUSH_API_KEY=                     # SEMrush API key
